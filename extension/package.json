{
  "name": "burnout-detector",
  "displayName": "Burnout Detector",
  "publisher": "hojun-lee",
  "description": "Help a desperate student's research on developer burnout. Anonymous behavior data collection for science.",
  "version": "0.2.3",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/monolail/burnout-detector"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "burnout-detector.helloWorld",
        "title": "Hello World"
      }
    ],
    "configuration": {
      "title": "Burnout Detector",
      "properties": {
        "burnoutDetector.enableDataCollection": {
          "type": "boolean",
          "default": false,
          "description": "번아웃 감지 연구를 위한 익명화된 데이터 수집 허용 여부 (v0.2.0: 파일 전환, 유휴 시간, 복사/붙여넣기 포함)"
        },
        "burnoutDetector.serverUrl": {
          "type": "string",
          "default": "https://burnout-backend-zr5p.onrender.com/api/upload",
          "description": "수집된 데이터를 전송할 서버의 URL 주소"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
